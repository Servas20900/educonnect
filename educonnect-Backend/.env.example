# ============ DJANGO CORE (PRODUCCIÓN) ============
SECRET_KEY=tu_secret_key_muy_largo_y_seguro_cambiar_en_produccion_NO_COMMITEAR
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,tu_ip_ec2,tu_dominio_cloudfront.cloudfront.net

# ============ DATABASE - PostgreSQL RDS ============
# Opción 1: DATABASE_URL (recomendado para AWS RDS)
DATABASE_URL=postgresql://postgres:tu_password@tu-rds-endpoint.region.rds.amazonaws.com:5432/educonnect_db

# Opción 2: Variables individuales (fallback)
DB_NAME=educonnect_db
DB_USER=postgres
DB_PASSWORD=tu_password_rds_muy_seguro
DB_HOST=tu-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ============ CLOUDINARY (Almacenamiento de archivos) ============
USE_CLOUDINARY=True
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key_aqui
CLOUDINARY_API_SECRET=tu_api_secret_aqui

# ============ CORS & SEGURIDAD ============
CORS_ALLOWED_ORIGINS=https://tu_dominio_cloudfront.cloudfront.net,http://localhost:5173,http://localhost:5174
CSRF_TRUSTED_ORIGINS=https://tu_dominio_cloudfront.cloudfront.net,http://localhost:5173,http://localhost:5174

# ============ JWT - AUTH COOKIES ============
AUTH_COOKIE_DOMAIN=tu_dominio_cloudfront.cloudfront.net
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=None

# ============ AWS (Identificación en logs) ============
AWS_CLOUDFRONT_DOMAIN=tu_dominio_cloudfront.cloudfront.net
AWS_EC2_HOST=tu_ip_ec2
AWS_EC2_IP=tu_ip_ec2

# ============ EMAIL (SMTP para producción) ============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_gmail
EMAIL_USE_TLS=True